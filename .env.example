# Copy to .env and adjust as needed. Do NOT commit real secrets.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=juridicflow

# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
QUEUE_NAME=document_jobs

# --- Upload limits (bytes) ---
MAX_UPLOAD_BYTES=26214400

# --- Embeddings ---
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Classification thresholds (calibrate with real data) ---
MINHASH_NEAR_DUP=0.80
CHUNK_SIM_THRESHOLD=0.80
CHUNK_SIM_FRACTION=0.60
SEMANTIC_RELATED=0.78
MINHASH_SEMANTIC_MAX=0.60

# --- Optional LLM (leave LLM_API_KEY empty for rules-only mode) ---
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
